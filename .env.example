# Salin ke .env dan sesuaikan
APP_NAME=MaturCapil Semarang API
APP_ENV=development
DEBUG=true

# Server (sesuai VITE_API_BASE_URL frontend: http://localhost:3000/api/v1)
HOST=0.0.0.0
PORT=3000

# MySQL — native / XAMPP (default XAMPP: user root, password kosong)
# Buat database "maturcapil_db" dulu di phpMyAdmin, lalu jalankan: python -m scripts.seed
DATABASE_URL=mysql+pymysql://root@localhost:3306/maturcapil_db?charset=utf8mb4
# Jika root punya password:
# DATABASE_URL=mysql+pymysql://root:password_anda@localhost:3306/maturcapil_db?charset=utf8mb4

# Railway (service backend) — internal URL saja, BUKAN MYSQL_PUBLIC_URL:
# DATABASE_URL=${{maturcapil_db.MYSQL_URL}}
# Python otomatis mengubah mysql:// → mysql+pymysql://
# Jika URL memakai /maturcapil_db, database dibuat otomatis saat startup (Railway default: /railway)

# JWT
SECRET_KEY=change-me-to-a-long-random-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173

# Upload
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=2
MAX_UPLOAD_INPUT_MB=15
MAX_COMPLAINT_PHOTOS=3
PUBLIC_BASE_URL=http://localhost:3000

# Email (kosongkan SMTP_HOST untuk mode dev: OTP dicetak ke log)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@maturcapil.id
SMTP_TLS=true

# OTP
OTP_EXPIRE_MINUTES=5
OTP_MAX_RESEND=3
OTP_RESEND_COOLDOWN_SECONDS=60

# Rate limit
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_MINUTES=15
